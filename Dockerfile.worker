# FFmpeg Worker - Alpine based
FROM alpine:3.18
RUN apk add --no-cache ffmpeg nodejs npm
RUN addgroup -g 1001 -S workergroup && adduser -S worker -u 1001
WORKDIR /app
# We will copy worker code here later
# COPY worker/package*.json ./
# RUN npm ci --production
# COPY worker/src ./src
USER worker
CMD ["node", "src/main.js"]
